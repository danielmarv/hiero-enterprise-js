{
    "name": "@hiero-enterprise/express",
    "version": "0.1.0",
    "description": "Express middleware for the Hiero network",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist"
    },
    "peerDependencies": {
        "@hiero-ledger/sdk": "^2.84.0",
        "express": ">=4"
    },
    "devDependencies": {
        "@hiero-enterprise/core": "workspace:*",
        "@types/express": "^5.0.0",
        "tsup": "^8.3.5"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=20.12.0"
    }
}
