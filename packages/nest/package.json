{
    "name": "@hiero-enterprise/nest",
    "version": "0.1.0",
    "description": "NestJS module for the Hiero network",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "test": "pnpm run test:integration",
        "test:unit": "vitest run test/integration",
        "test:integration": "vitest run test/integration",
        "test:watch": "vitest test/integration"
    },
    "peerDependencies": {
        "@hiero-enterprise/core": "workspace:*",
        "@nestjs/common": "^11.1.24",
        "@nestjs/core": "^11.1.24"
    },
    "devDependencies": {
        "@hiero-enterprise/core": "workspace:*",
        "@nestjs/common": "^11.1.24",
        "@nestjs/core": "^11.1.24",
        "@nestjs/testing": "^11.1.24",
        "reflect-metadata": "^0.2.0",
        "tsup": "^8.3.5",
        "vitest": "^4.1.7"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=20.12.0"
    }
}
