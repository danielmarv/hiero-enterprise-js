{
    "name": "@hiero-enterprise/core",
    "version": "0.1.0",
    "description": "Core services, repositories, and data models for the Hiero network",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "repository": "https://github.com/hiero-hackers/hiero-enterprise-js",
    "bugs": "https://github.com/hiero-hackers/hiero-enterprise-js/issues",
    "keywords": [
        "core",
        "hiero",
        "hedera",
        "transactions",
        "hiero-enterprise"
    ],
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "test:unit": "vitest run -c test/vitest.config.ts",
        "test:unit:coverage": "vitest run -c test/vitest.config.ts --coverage",
        "test:integration": "vitest run -c test/vitest-integration.config.ts",
        "test:integration:coverage": "vitest run -c test/vitest-integration.config.ts --coverage",
        "test": "pnpm run test:unit && pnpm run test:integration"
    },
    "dependencies": {
        "@hiero-ledger/sdk": "^2.84.0",
        "bignumber.js": "^11.1.3"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.1.8"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
