{
    "name": "@hiero-enterprise/core",
    "version": "0.1.0",
    "description": "Core services, repositories, and data models for the Hiero network",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./testing": {
            "types": "./dist/testing/index.d.ts",
            "import": "./dist/testing/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "test:unit": "vitest run test/unit",
        "test:integration": "vitest run -c vitest.config.integration.ts",
        "test": "pnpm run test:unit && pnpm run test:integration",
        "test:watch": "vitest test/unit"
    },
    "dependencies": {
        "@hiero-ledger/sdk": "^2.84.0"
    },
    "devDependencies": {
        "vitest": "^4.1.7",
        "@types/node": "^25.9.1"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=20.12.0"
    }
}
