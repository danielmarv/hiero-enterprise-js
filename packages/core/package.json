{
    "name": "@hiero-enterprise/core",
    "version": "0.1.0",
    "description": "Core services, repositories, and data models for Hiero/Hedera networks",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./testing": {
            "types": "./dist/testing/index.d.ts",
            "import": "./dist/testing/index.js"
        }
    },
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "test:unit": "vitest run test/unit",
        "test:integration": "vitest run -c vitest.config.integration.ts",
        "test": "pnpm run test:unit && pnpm run test:integration",
        "test:watch": "vitest test/unit"
    },
    "dependencies": {
        "@hashgraph/sdk": "^2.55.0",
        "dotenv": "^16.4.7"
    },
    "devDependencies": {
        "vitest": "^3.0.0"
    },
    "engines": {
        "node": ">=20"
    }
}
