{
    "name": "@hiero-enterprise/fastify",
    "version": "0.1.0",
    "description": "Fastify plugin for the Hiero network",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "test": "pnpm run test:integration",
        "test:unit": "vitest run test/integration",
        "test:integration": "vitest run test/integration",
        "test:watch": "vitest test/integration"
    },
    "dependencies": {
        "fastify-plugin": "^5.1.0"
    },
    "peerDependencies": {
        "@hiero-ledger/sdk": "^2.84.0",
        "fastify": ">=5"
    },
    "devDependencies": {
        "@hiero-enterprise/core": "workspace:*",
        "fastify": "^5.8.5",
        "tsup": "^8.3.5",
        "vitest": "^4.1.7"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=20.12.0"
    }
}
