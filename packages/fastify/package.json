{
    "name": "@hiero-enterprise/fastify",
    "version": "0.1.0",
    "description": "Fastify plugin for the Hiero network",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "repository": "https://github.com/hiero-hackers/hiero-enterprise-js",
    "bugs": "https://github.com/hiero-hackers/hiero-enterprise-js/issues",
    "keywords": [
        "hiero",
        "hedera",
        "fastify",
        "transactions",
        "hiero-enterprise"
    ],
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "test": "pnpm run test:integration",
        "test:unit": "vitest run test/integration",
        "test:integration": "vitest run test/integration",
        "test:watch": "vitest test/integration"
    },
    "dependencies": {
        "@hiero-enterprise/core": "workspace:*",
        "fastify-plugin": "^5.1.0"
    },
    "peerDependencies": {
        "fastify": "^5.8.5"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
