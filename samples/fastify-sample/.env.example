# ─── Required ────────────────────────────────────────────────────────────────

# Network to connect to: "testnet", "mainnet", "previewnet", or a custom network name
HIERO_NETWORK=testnet

# Your operator account ID on the Hiero network
HIERO_OPERATOR_ID=0.0.YOUR_ACCOUNT_ID

# Your operator private key (raw hex string — do NOT include 0x prefix)
HIERO_OPERATOR_KEY=your_private_key_here

# How to parse the operator key. Required because key format cannot be auto-detected.
#   ECDSA   — secp256k1 key, compatible with EVM wallets and most providers
#   ED25519 — native Hiero Ed25519 key
#   DER     — DER-encoded key with ASN.1 headers (e.g. 302e020100...)
HIERO_OPERATOR_KEY_TYPE=ecdsa

# ─── Optional ────────────────────────────────────────────────────────────────

# Mirror node REST API base URL (auto-resolved for known networks if omitted)
# HIERO_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# ─── SDK Tuning (all optional) ───────────────────────────────────────────────

# Request timeout for SDK client calls in milliseconds
# HIERO_REQUEST_TIMEOUT_MS=120000

# gRPC deadline per node request in milliseconds
# HIERO_GRPC_DEADLINE_MS=10000

# Max transaction submission attempts before failing
# HIERO_MAX_ATTEMPTS=10

# Minimum backoff between retries in milliseconds
# HIERO_MIN_BACKOFF_MS=250

# Maximum backoff between retries in milliseconds
# HIERO_MAX_BACKOFF_MS=8000

# ─── Mirror Node Client (all optional) ───────────────────────────────────────

# Timeout for mirror node REST requests in milliseconds
# HIERO_MIRROR_NODE_TIMEOUT_MS=10000

# Max retries for mirror node REST requests
# HIERO_MIRROR_NODE_MAX_RETRIES=3
