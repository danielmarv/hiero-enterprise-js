{
    "name": "hiero-enterprise-js",
    "version": "0.1.0",
    "private": true,
    "description": "Enterprise-grade TypeScript library for Hiero networks",
    "type": "module",
    "license": "Apache-2.0",
    "scripts": {
        "build": "pnpm -r run build",
        "test": "pnpm -r run test",
        "test:unit": "pnpm -r run test:unit",
        "test:integration": "pnpm -r run test:integration",
        "test:watch": "pnpm -r run test:watch",
        "lint": "eslint . --fix",
        "format": "prettier --write .",
        "example": "pnpm --filter @hiero-enterprise/examples examples"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.1",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-security": "^4.0.0",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.59.4"
    },
    "engines": {
        "node": ">=20.12.0",
        "pnpm": ">=9"
    }
}
